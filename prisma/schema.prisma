// prisma/schema.prisma
// BugHunter — PostgreSQL schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────

enum Plan {
  free
  pro
  team
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  githubLogin    String?  @unique
  githubToken    String?  @db.Text

  plan             Plan      @default(free)
  planActivatedAt  DateTime?
  planExpiresAt    DateTime?
  trialEndsAt      DateTime?

  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique

  monthlyCommits Int      @default(0)
  monthlyResetAt DateTime @default(now())

  accounts Account[]
  sessions Session[]
  repos    Repository[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Repositories ─────────────────────────────────

model Repository {
  id            String   @id @default(cuid())
  userId        String
  githubId      Int
  owner         String
  name          String
  fullName      String
  description   String?
  private       Boolean  @default(false)
  language      String?
  webhookId     Int?
  webhookActive Boolean  @default(false)
  active        Boolean  @default(true)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  commits    Commit[]
  dailyStats DailyStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, githubId])
  @@index([userId])
}

// ─── Commits ──────────────────────────────────────

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  SAFE
  PENDING
  FAILED
}

model Commit {
  id           String   @id @default(cuid())
  repositoryId String
  sha          String
  message      String   @db.Text

  authorName   String
  authorEmail  String
  authorLogin  String?
  authorAvatar String?

  branch String?
  url    String?

  riskLevel       RiskLevel @default(PENDING)
  analysisRaw     String?   @db.Text
  predictedBugs   Json?
  affectedSystems Json?
  recommendation  String?   @db.Text
  confidence      Int?

  filesChanged Int @default(0)
  additions    Int @default(0)
  deletions    Int @default(0)

  analyzedAt   DateTime?
  statusPosted Boolean @default(false)

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  files      CommitFile[]

  createdAt DateTime @default(now())

  @@unique([repositoryId, sha])
  @@index([repositoryId])
  @@index([riskLevel])
  @@index([createdAt])
}

model CommitFile {
  id       String @id @default(cuid())
  commitId String

  filename  String
  status    String
  additions Int @default(0)
  deletions Int @default(0)
  patch     String? @db.Text

  commit Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@index([commitId])
}

// ─── Analytics ────────────────────────────────────

model DailyStats {
  id           String   @id @default(cuid())
  repositoryId String
  date         DateTime @db.Date

  totalCommits Int @default(0)

  critical Int @default(0)
  high     Int @default(0)
  medium   Int @default(0)
  low      Int @default(0)
  safe     Int @default(0)

  avgConfidence Float?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, date])
  @@index([repositoryId])
  @@index([date])
}