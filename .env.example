# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL — Neon recommended for serverless (free tier available)
# https://neon.tech → Create project → copy connection string
DATABASE_URL="mongodb+srv://zerosync:UH0QuJqXFZ3rBv4l@cluster0.l3ec3k6.mongodb.net/zerosync?retryWrites=true&w=majority"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="pMGQJ6TBn8jb6fndT6WAhtKQMCj45Td0Aklz8gveJ/M="
AUTH_URL="http://localhost:3000"   # Change to your prod URL on deploy

# GitHub OAuth App (github.com/settings/developers → New OAuth App)
#   Homepage URL:      http://localhost:3000
#   Callback URL:      http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your_github_oauth_app_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_app_client_secret"

# ─── Token Encryption (FIX 1) ─────────────────────────────────────────────────
# AES-256 key — MUST be exactly 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET="your_64_hex_char_encryption_key_here_generate_dont_invent"

# ─── GitHub API ───────────────────────────────────────────────────────────────
# Fine-grained PAT or classic PAT with: repo, admin:repo_hook
GITHUB_TOKEN="ghp_your_github_personal_access_token"

# Webhook secret — any random string (used to verify GitHub signatures)
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET="your_random_webhook_secret"

# ─── Anthropic ────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-your_anthropic_api_key"

# ─── Rate Limiting — Upstash Redis (FIX 3) ────────────────────────────────────
# https://upstash.com → Create Redis database → REST API tab
# Optional in dev (falls back to in-memory) — REQUIRED in production
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token"

# ─── Background Jobs — Inngest (FIX 6) ────────────────────────────────────────
# https://inngest.com → Create app → get keys
# Optional in dev (uses Inngest Dev Server) — REQUIRED in production
INNGEST_EVENT_KEY="your_inngest_event_key"
INNGEST_SIGNING_KEY="signkey-prod-your_inngest_signing_key"

